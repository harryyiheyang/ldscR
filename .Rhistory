library(bigsnpr)
data("PCSK9")
data("hapmap3")
data("EURLDSC")
PCSK9=merge_union(gwas_data_list=PCSK9,ref_panel=hapmap3,missing.thres=0.9)
Boundary=list(intercept.lower=0.5,intercept.upper=1.5,h2.upper=0.95,gcov.lower=-0.95,gcov.upper=0.95,ecov.lower=-0.95,ecov.upper=0.95)
fitPCSK9=local_ldscR(GWAS_List=PCSK9$gwas_data_list,LDSC=EURLDSC,Boundary=Boundary)
corrplot(fitPCSK9$GCovEst,method="color",is.corr=F,addCoef.col = "black",tl.cex=0.5)
library(corrplot)
corrplot(fitPCSK9$GCovEst,method="color",is.corr=F,addCoef.col = "black",tl.cex=0.5)
corrplot(fitPCSK9$ECovEst,method="color",is.corr=F,addCoef.col = "black",tl.cex=0.5)
TIME=matrix(0,12,2)%>%as.data.frame(.)
A1=list()
A2=list()
for(i in 1:12){
t_1=Sys.time()
Ajoint=merge(PCSK9[[i]],EURLDSC,by="SNP")
bigsnpr1=snp_ldsc(
ld_score=Ajoint$LDSC,
ld_size=length(Ajoint$SNP),
chi2=Ajoint$Zscore^2,
sample_size=Ajoint$N,
blocks = 50,
intercept = NULL,
chi2_thr1 = 30,
chi2_thr2 = Inf,
ncores = 1
)
t_1=Sys.time()-t_1
t_2=Sys.time()
bigsnpr2=snp_ldsc(
ld_score=Ajoint$LDSC,
ld_size=length(Ajoint$SNP),
chi2=Ajoint$Zscore^2,
sample_size=Ajoint$N,
blocks = 100,
intercept = NULL,
chi2_thr1 = 30,
chi2_thr2 = Inf,
ncores = 1
)
t_2=Sys.time()-t_2
A1[[i]]=bigsnpr1
A2[[i]]=bigsnpr2
TIME[i,]=c(t1,t2)
print(TIME[i,])
}
Ajoint=merge(PCSK9[[i]],EURLDSC,by="SNP")
PCSK9[[i]]
